# ==============================================================================
# Local Development Infrastructure Environment Configuration
# Copy this file to infrastructure/docker/.env prior to running docker compose
# ==============================================================================

# PostgreSQL Configuration
POSTGRES_DB=enterprise_ai_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password
POSTGRES_PORT=5432

# Redis Configuration
REDIS_PASSWORD=redis_secure_password
REDIS_PORT=6379

# Qdrant Vector DB Configuration
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# pgAdmin Management UI Configuration
PGADMIN_DEFAULT_EMAIL=admin@enterprise-ai.internal
PGADMIN_DEFAULT_PASSWORD=admin_secure_password
PGADMIN_PORT=5050
