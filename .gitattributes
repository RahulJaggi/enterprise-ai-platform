# Set default behavior to automatic text normalization (LF line endings)
* text=auto eol=lf

# Explicitly declare text files to always have LF
*.js       text eol=lf
*.jsx      text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.py       text eol=lf
*.sh       text eol=lf
*.env*     text eol=lf
.editorconfig text eol=lf
.gitignore    text eol=lf
.gitattributes text eol=lf

# Denote binary files (will not undergo LF/CRLF conversion and binary diffs used)
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.svg      binary
*.pdf      binary
*.wof      binary
*.woff2    binary
*.eot      binary
*.ttf      binary
*.otf      binary
*.zip      binary
*.tar.gz   binary
